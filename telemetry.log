despaceName":"didactic-space-eureka-x6r55rxqjwx2prr","eventName":"DocumentChangeEvent","eventTime":1773759606087,"sessionId":"d2c39d5f-80bd-4523-85ee-7c5b11e1c3351773757082563","machineId":"2a9131dcdef18a34c78b7dd572a65d65cdb04117132abd0bf1ef88bf20e87f9f","documentUri":"file:///workspaces/aireli-lecture-task/apps/api/src/models/User.ts","documentId":13,"operation":"replace","value":"import sqlite3 from 'sqlite3';\nimport { open, Database } from 'sqlite';\nimport path from 'path';\nimport bcrypt from 'bcryptjs';\nimport { PlatformUser } from \"@enterprise-commerce/core/platform/types\"\nimport openDb from '../db/db';\n\nexport const createUser = async (user: PlatformUser): Promise<Pick<PlatformUser, \"id\"> | null> => {\n  const db = await openDb();\n\n  const hashedPassword = await bcrypt.hash(user.password, 10);\n\n  const result = await db.run(\n    'INSERT INTO users (email, password) VALUES (?, ?)',\n    user.email,\n    hashedPassword\n  );\n\n  const id = result.lastID;\n\n  await db.close();\n\n  return id ? { id } : null;\n};\n\nexport const findUserById = async (id: string): Promise<PlatformUser | null> => {\n  const db = await openDb();\n  const user = await db.get<PlatformUser>('SELECT * FROM users WHERE id = ?', id);\n  await db.close();\n  return user || null;\n};\n\n/**\n * Compares a plain text password with a hashed password.\n *\n * This function uses bcrypt to asynchronously compare a plain text password with a hashed password \n * to determine if they match.\n *\n * @param {string} password - The plain text password to be compared. (input from user when trying to login)\n * @param {string} hashedPassword - The hashed password to compare against. (encrypted password stored in database)\n * @returns {Promise<boolean>} - A promise that resolves to `true` if the passwords match, \n *                               and `false` otherwise.\n */\nexport const comparePasswords = async (password: string, hashedPassword: string): Promise<boolean> => {\n  return bcrypt.compare(password, hashedPassword); \n};","rangeOffset":"0","rangeLength":"1282","rangestart_line":"0","rangestart_character":"0","rangeend_line":"30","rangeend_character":"0"},{"codespaceName":"didactic-space-eureka-x6r55rxqjwx2prr","eventName":"DocumentSaveEvent","eventTime":1773759606806,"sessionId":"d2c39d5f-80bd-4523-85ee-7c5b11e1c3351773757082563","machineId":"2a9131dcdef18a34c78b7dd572a65d65cdb04117132abd0bf1ef88bf20e87f9f","documentUri":"file:///workspaces/aireli-lecture-task/apps/api/src/models/User.ts","documentId":13,"operation":"save","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"didactic-space-eureka-x6r55rxqjwx2prr","eventName":"WindowStateChangeEvent","eventTime":1773759609505,"sessionId":"d2c39d5f-80bd-4523-85ee-7c5b11e1c3351773757082563","machineId":"2a9131dcdef18a34c78b7dd572a65d65cdb04117132abd0bf1ef88bf20e87f9f","documentUri":"","documentId":0,"operation":"windowBlurred","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"didactic-space-eureka-x6r55rxqjwx2prr","eventName":"DocumentCloseEvent","eventTime":1773759625964,"sessionId":"d2c39d5f-80bd-4523-85ee-7c5b11e1c3351773757082563","machineId":"2a9131dcdef18a34c78b7dd572a65d65cdb04117132abd0bf1ef88bf20e87f9f","documentUri":"file:///workspaces/aireli-lecture-task/apps/api/src/routes.ts","documentId":11,"operation":"close","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"didactic-space-eureka-x6r55rxqjwx2prr","eventName":"WindowStateChangeEvent","eventTime":1773759633343,"sessionId":"d2c39d5f-80bd-4523-85ee-7c5b11e1c3351773757082563","machineId":"2a9131dcdef18a34c78b7dd572a65d65cdb04117132abd0bf1ef88bf20e87f9f","documentUri":"","documentId":0,"operation":"windowFocused","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"didactic-space-eureka-x6r55rxqjwx2prr","eventName":"ActiveEditorChangeEvent","eventTime":1773759634986,"sessionId":"d2c39d5f-80bd-4523-85ee-7c5b11e1c3351773757082563","machineId":"2a9131dcdef18a34c78b7dd572a65d65cdb04117132abd0bf1ef88bf20e87f9f","documentUri":"file:///workspaces/aireli-lecture-task/apps/api/src/controllers/auth.controllers.ts","documentId":12,"operation":"focus","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"didactic-space-eureka-x6r55rxqjwx2prr","eventName":"DocumentChangeEvent","eventTime":1773759636332,"sessionId":"d2c39d5f-80bd-4523-85ee-7c5b11e1c3351773757082563","machineId":"2a9131dcdef18a34c78b7dd572a65d65cdb04117132abd0bf1ef88bf20e87f9f","documentUri":"file:///workspaces/aireli-lecture-task/apps/api/src/controllers/auth.controllers.ts","documentId":12,"operation":"replace","value":"import { Request, Response } from 'express';\nimport jwt from 'jsonwebtoken';\nimport { PlatformUser } from \"@enterprise-commerce/core/platform/types\"\nimport { createUser } from \"../models/User\"\n\nexport const registerUser = async (req: Request, res: Response): Promise<void> => {\n  try {\n    const { email, password } = req.body;\n\n    if (!email || !password) {\n      res.status(400).json({ message: 'Email and password are required' });\n      return;\n    }\n\n    const newUser: PlatformUser = {\n      id: null,\n      email,\n      password\n    };\n\n    const createdUser = await createUser(newUser);\n\n    if (!createdUser) {\n      res.status(500).json({ message: 'Failed to create user' });\n      return;\n    }\n\n    res.status(201).json(createdUser);\n  } catch (error) {\n    console.error(error);\n    res.status(500).json({ message: 'Internal server error' });\n  }\n};","rangeOffset":"0","rangeLength":"432","rangestart_line":